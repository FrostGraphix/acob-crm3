UPSTREAM_API_URL=http://your-upstream-host:9310
UPSTREAM_USERNAME=
UPSTREAM_PASSWORD=
JWT_SECRET=replace-with-a-strong-secret
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173
ENABLE_METRICS=true
SESSION_STORE_MODE=redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_CONNECT_TIMEOUT_MS=750
REDIS_KEY_PREFIX=acob:session:
RUNTIME_STATE_STORE_MODE=redis
RUNTIME_STATE_KEY_PREFIX=acob:runtime:
SCHEDULER_COORDINATION_MODE=redis
SCHEDULER_LEADER_KEY_PREFIX=acob:leader:
SCHEDULER_LEADER_LEASE_MS=20000
SCHEDULER_LEADER_HEARTBEAT_MS=5000
STRICT_DEPENDENCY_STARTUP=false
ENABLE_ANALYSIS_ENGINE=false
ENABLE_SITE_CONSUMPTION_ENGINE=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_PER_WINDOW=240
RATE_LIMIT_TRUST_FORWARDED_FOR=false
SUPABASE_AUTH_ENABLED=false
SUPABASE_STORAGE_ENABLED=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
RUN_SUPABASE_INTEGRATION_TESTS=false
SUPABASE_TEST_EMAIL=
SUPABASE_TEST_PASSWORD=
SUPABASE_TEST_STORAGE_PREFIX=acob-crm3/integration
